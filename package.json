{
  "name": "veda-ingest-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:check": "yarn lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "vitest",
    "test:e2e": "yarn build && yarn playwright test",
    "test:coverage": "vitest run --coverage",
    "test:coverage:threshold": "vitest run --coverage --reporter=verbose",
    "type-check": "tsc --noEmit",
    "analyze": "ANALYZE=true yarn build",
    "deps:check": "yarn outdated",
    "deps:audit": "yarn audit",
    "clean": "rm -rf .next out coverage test-results"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@ant-design/nextjs-registry": "^1.0.2",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@aws-amplify/adapter-nextjs": "^1.7.2",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/client-secrets-manager": "^3.1019.0",
    "@aws-sdk/client-sts": "^3.1020.0",
    "@aws-sdk/s3-request-presigner": "^3.1020.0",
    "@octokit/auth-app": "^7.1.3",
    "@octokit/rest": "^21.0.2",
    "@rjsf/antd": "^6.2.5",
    "@rjsf/core": "^6.2.5",
    "@rjsf/utils": "^6.2.5",
    "@rjsf/validator-ajv8": "^6.2.5",
    "@uiw/react-textarea-code-editor": "^3.1.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "antd": "5.29.1",
    "aws-amplify": "^6.16.3",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "framer-motion": "^12.4.7",
    "json-schema": "^0.4.0",
    "leaflet": "^1.9.4",
    "lodash": "~4.17.23",
    "next": "15.5.14",
    "next-auth": "^5.0.0-beta.30",
    "next-remove-imports": "^1.0.12",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "virtual-react-json-diff": "^1.0.15"
  },
  "devDependencies": {
    "@octokit/types": "^13.6.2",
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/leaflet": "^1.9.16",
    "@types/lodash": "^4.17.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "babel-loader": "^10.0.0",
    "eslint": "^8",
    "eslint-config-next": "15.5.14",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^2.5.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.11",
    "msw": "^2.7.0",
    "pin-github-action": "3.4.0",
    "playwright-msw": "^3.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "3.2.4"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "yarn lint:fix",
      "prettier --write"
    ]
  },
  "resolutions": {
    "fast-xml-parser": "5.5.8",
    "eslint/minimatch": "3.1.4",
    "@eslint/eslintrc/minimatch": "3.1.4",
    "@humanwhocodes/config-array/minimatch": "3.1.4",
    "eslint-plugin-import/minimatch": "3.1.4",
    "eslint-plugin-jsx-a11y/minimatch": "3.1.4",
    "eslint-plugin-react/minimatch": "3.1.4"
  },
  "packageManager": "yarn@4.13.0"
}
